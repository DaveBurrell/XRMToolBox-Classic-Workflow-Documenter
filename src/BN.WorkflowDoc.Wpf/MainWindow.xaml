<Window x:Class="BN.WorkflowDoc.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BridgeNexa - Classic Workflow Documenter"
        Icon="Assets/BridgeNexa.ico"
        Width="980" Height="900"
        MinWidth="860" MinHeight="820"
        WindowStartupLocation="CenterScreen"
        Background="#EFF1F6"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Window.Resources>
        <LinearGradientBrush x:Key="HeroGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#172B66" Offset="0"/>
            <GradientStop Color="#4B1FA2" Offset="0.56"/>
            <GradientStop Color="#D21D7E" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="24,22"/>
            <Setter Property="BorderBrush" Value="#ECEFF4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="18" Opacity="0.08" Color="#1D2340"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#495366"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#172033"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#D7DCE8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FBFCFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#8A4BFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#8A4BFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="26,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="11" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#7540DB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#6635BE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#CFC4EE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineBtn" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#2A3243"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderBrush" Value="#D7DCE8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F4F7FF"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#AAB5CD"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#F6F8FC"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#E2E6EF"/>
                                <Setter Property="Foreground" Value="#9BA4B6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallOutlineBtn" TargetType="Button" BasedOn="{StaticResource OutlineBtn}">
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <Style x:Key="TopTabRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#2A3243"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" CornerRadius="9" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F6F8FC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SegmentRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#2A3243"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Background="#FFFFFF" BorderBrush="#D7DCE8" BorderThickness="1" CornerRadius="11" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="Dot" Width="10" Height="10" Fill="#D6DCE8" Stroke="#C1CADB" StrokeThickness="1" Margin="0,0,8,0"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#8A4BFF"/>
                                <Setter TargetName="Root" Property="Background" Value="#F4EEFF"/>
                                <Setter TargetName="Dot" Property="Fill" Value="#8A4BFF"/>
                                <Setter TargetName="Dot" Property="Stroke" Value="#6B34D6"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F9FAFD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="170"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeroGradient}" Padding="26,18,26,22">
            <StackPanel>
                <TextBlock Text="Classic Workflow Documenter"
                           FontSize="39"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Transform your Dynamics 365 unmanaged solution packages into comprehensive workflow documentation with intelligent automation."
                           FontSize="14"
                           Foreground="#D9E0FF"
                           TextWrapping="Wrap"
                           MaxWidth="760"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,-20,0,0">
            <StackPanel Margin="18,0,18,14">

                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel x:Name="ConfigurePanel">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#EEE9FF" Width="28" Height="28" CornerRadius="14" Margin="0,0,8,0">
                                <TextBlock Text="R" Foreground="#6E37DA" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Run Mode" FontSize="28" FontWeight="Bold" Foreground="#1C2537" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <RadioButton x:Name="SingleRunRadio"
                                         Style="{StaticResource SegmentRadio}"
                                         Content="Single Solution"
                                         IsChecked="True"
                                         Checked="RunMode_Changed"
                                         Width="260"/>
                            <RadioButton x:Name="BatchRunRadio"
                                         Style="{StaticResource SegmentRadio}"
                                         Content="Batch Processing"
                                         Checked="RunMode_Changed"
                                         Width="260"
                                         Margin="0"/>
                        </StackPanel>

                        <Border x:Name="DropZoneBorder"
                                CornerRadius="14"
                                BorderBrush="#CBD3E2"
                                BorderThickness="0"
                                Background="#F8FAFD"
                                Padding="0,34"
                                Margin="0,0,0,16"
                                AllowDrop="True"
                                Drop="DropZone_Drop"
                                DragOver="DropZone_DragOver"
                                DragLeave="DropZone_DragLeave">
                            <Grid>
                                <Rectangle Margin="8"
                                           RadiusX="12"
                                           RadiusY="12"
                                           Stroke="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=Border}}"
                                           StrokeThickness="2"
                                           StrokeDashArray="4,4"
                                           Fill="Transparent"
                                           IsHitTestVisible="False"/>
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="60" Height="60" Background="#E9EEF7" CornerRadius="12" HorizontalAlignment="Center">
                                        <TextBlock Text="PKG" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#7583A2"/>
                                    </Border>
                                    <TextBlock Text="Drop solution package here" HorizontalAlignment="Center" FontSize="24" FontWeight="SemiBold" Foreground="#2A3243" Margin="0,14,0,4"/>
                                    <TextBlock Text="or click Browse to select files" HorizontalAlignment="Center" FontSize="13" Foreground="#909AB0" Margin="0,0,0,10"/>
                                    <Border Background="#FFFFFF" BorderBrush="#E1E6F0" BorderThickness="1" CornerRadius="9" Padding="12,6" HorizontalAlignment="Center">
                                        <TextBlock Text="Supports .ZIP files only" FontSize="12" Foreground="#616D86"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock x:Name="ZipInputLabel" Text="Solution ZIP File" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ZipPathBox"
                                     Style="{StaticResource Input}"
                                     IsReadOnly="True"
                                     Foreground="#9AA2B5"
                                     Text="No file selected"/>
                            <Button Content="Browse"
                                    Style="{StaticResource OutlineBtn}"
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Click="BrowseZip_Click"/>
                        </Grid>

                        <Border x:Name="BatchInputPanel"
                                Background="#F8FAFD"
                                CornerRadius="10"
                                BorderBrush="#E5EAF3"
                                BorderThickness="1"
                                Padding="12,10"
                                Margin="0,0,0,16"
                                Visibility="Collapsed">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                                    <Button Content="Add ZIPs" Style="{StaticResource SmallOutlineBtn}" Margin="0,0,8,0" Click="AddBatchZips_Click"/>
                                    <Button Content="Clear" Style="{StaticResource SmallOutlineBtn}" Click="ClearBatchZips_Click"/>
                                </StackPanel>
                                <ListBox x:Name="BatchZipList"
                                         Height="96"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="12"
                                         Foreground="#3A4457"/>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Output Folder" Style="{StaticResource FieldLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="OutputFolderBox" Style="{StaticResource Input}"/>
                                    <Button Content="Browse" Style="{StaticResource OutlineBtn}" Grid.Column="1" Margin="8,0,0,0" Click="BrowseOutput_Click"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Output Mode" Style="{StaticResource FieldLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <RadioButton x:Name="ModeDocxRadio"
                                                 Style="{StaticResource SegmentRadio}"
                                                 Grid.Column="0"
                                                 Margin="0,0,6,0"
                                                 Content="DOCX Files"
                                                 IsChecked="True"/>
                                    <RadioButton x:Name="ModePackRadio"
                                                 Style="{StaticResource SegmentRadio}"
                                                 Grid.Column="1"
                                                 Margin="6,0,0,0"
                                                 Content="ZIP Archive"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Narrative Tone" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="NarrativeToneBox"
                                          SelectedIndex="0"
                                          Padding="8,6"
                                          FontSize="13"
                                          Background="#FBFCFF"
                                          BorderBrush="#D7DCE8"
                                          BorderThickness="1">
                                    <ComboBoxItem Content="Business (Plain English)"/>
                                    <ComboBoxItem Content="Technical"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Diagram Detail" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="DiagramDetailBox"
                                          SelectedIndex="1"
                                          Padding="8,6"
                                          FontSize="13"
                                          Background="#FBFCFF"
                                          BorderBrush="#D7DCE8"
                                          BorderThickness="1">
                                    <ComboBoxItem Content="Standard"/>
                                    <ComboBoxItem Content="Detailed"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                            <Button x:Name="CancelButton"
                                    Content="Cancel"
                                    Style="{StaticResource OutlineBtn}"
                                    Visibility="Collapsed"
                                    Margin="0,0,10,0"
                                    Click="Cancel_Click"/>
                            <Button x:Name="GenerateButton"
                                    Content="Generate Documentation"
                                    Style="{StaticResource PrimaryBtn}"
                                    IsEnabled="False"
                                    Click="Generate_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="ProgressCard" Style="{StaticResource Card}" Margin="0,0,0,14" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Generating..." FontSize="15" FontWeight="SemiBold" Foreground="#1D2740" Margin="0,0,0,12"/>
                        <ProgressBar x:Name="MainProgress" Height="10" IsIndeterminate="True" Foreground="#8A4BFF" Margin="0,0,0,10"/>
                        <TextBlock x:Name="StatusText" Text="Initializing..." FontSize="13" Foreground="#5E6882"/>
                        <TextBlock x:Name="ProgressDetailText" FontSize="11" Foreground="#8D98AF" Margin="0,4,0,0"/>
                        <TextBlock x:Name="ProgressTimeText" FontSize="11" Foreground="#8D98AF" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border x:Name="ResultsCard" Style="{StaticResource Card}" Margin="0,0,0,14" Visibility="Collapsed">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="ResultsTitle" FontSize="15" FontWeight="SemiBold" Foreground="#1D2740"/>
                                <TextBlock x:Name="ResultsSummary" FontSize="12" Foreground="#69758D" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                <Button x:Name="OpenFolderBtn" Content="Open Folder" Style="{StaticResource OutlineBtn}" Margin="0,0,8,0" Click="OpenFolder_Click"/>
                                <Button x:Name="OpenArchiveBtn" Content="Open Archive" Style="{StaticResource OutlineBtn}" Visibility="Collapsed" Click="OpenArchive_Click"/>
                            </StackPanel>
                        </Grid>

                        <ItemsControl x:Name="FileList" Margin="0,0,0,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8FAFD" CornerRadius="8" BorderBrush="#E4E9F2" BorderThickness="1" Padding="12,8" Margin="0,0,0,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FileName}" FontSize="12" FontWeight="SemiBold" Foreground="#1A2233"/>
                                                <TextBlock Text="{Binding FilePath}" FontSize="10" Foreground="#8E98AE" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Button Content="Open" Grid.Column="2" Tag="{Binding FilePath}" Style="{StaticResource SmallOutlineBtn}" Click="OpenFile_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border x:Name="BatchResultsPanel"
                                Background="#F8FAFD"
                                CornerRadius="10"
                                BorderBrush="#E4E9F2"
                                BorderThickness="1"
                                Padding="12,10"
                                Margin="0,0,0,12"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Batch Solution Results" FontSize="13" FontWeight="SemiBold" Foreground="#1D2740" Margin="0,0,0,8"/>
                                <ItemsControl x:Name="BatchResultsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" CornerRadius="7" BorderBrush="#E4E9F2" BorderThickness="1" Padding="10,8" Margin="0,0,0,5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding SolutionName}" FontSize="12" FontWeight="SemiBold" Foreground="#1A2233"/>
                                                        <TextBlock Text="{Binding SummaryLine}" FontSize="11" Foreground="#69758D" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="Open Folder" Tag="{Binding OutputFolder}" Style="{StaticResource SmallOutlineBtn}" Click="OpenPath_Click"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border x:Name="WarningsPanel"
                                Background="#FFF8E8"
                                CornerRadius="10"
                                BorderBrush="#F7D28D"
                                BorderThickness="1"
                                Padding="14,10"
                                Visibility="Collapsed">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="WarningsHeader" FontSize="13" FontWeight="SemiBold" Foreground="#85520F" VerticalAlignment="Center"/>
                                    <Button x:Name="WarningsToggleBtn" Grid.Column="1" Content="Show Details" Style="{StaticResource SmallOutlineBtn}" Click="WarningsToggle_Click"/>
                                </Grid>
                                <ItemsControl x:Name="WarningsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="12" Foreground="#85520F" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border x:Name="ErrorCard"
                        Background="#FEF2F2"
                        CornerRadius="10"
                        BorderBrush="#F1A3A3"
                        BorderThickness="1"
                        Padding="20,16"
                        Margin="0,0,0,14"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Generation Failed" FontSize="14" FontWeight="SemiBold" Foreground="#991B1B" Margin="0,0,0,8"/>
                        <TextBlock x:Name="ErrorMessageText" FontSize="13" Foreground="#7F1D1D" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

